    {
        "id": "fb9e73e8c3b45e6f",
        "type": "function",
        "z": "cf81ea95a4dcbf60",
        "name": "Preparar INSERT MySQL",
        "func": "const dados = msg.payload;\n\nmsg.topic = `\nINSERT INTO leituras_iot \n(distancia_cm, luminosidade, status_aproximacao, status_luminosidade, status_geral)\nVALUES (?, ?, ?, ?, ?)\n`;\n\nmsg.payload = [\n    dados.distancia_cm,\n    dados.luminosidade,\n    dados.status_aproximacao,\n    dados.status_luminosidade,\n    dados.status_geral\n];\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
