    {
        "id": "f3c28216694b43ea",
        "type": "function",
        "z": "cf81ea95a4dcbf60",
        "name": "Separar dados dos sensores",
        "func": "const dados = msg.payload;\n\nconst distancia = {\n    payload: dados.distancia_cm\n};\n\nconst luminosidade = {\n    payload: dados.luminosidade\n};\n\nconst statusAproximacao = {\n    payload: dados.status_aproximacao\n};\n\nconst statusLuminosidade = {\n    payload: dados.status_luminosidade\n};\n\nconst statusGeral = {\n    payload: dados.status_geral\n};\n\nconst graficoDistancia = {\n    payload: dados.distancia_cm\n};\n\nconst graficoLuminosidade = {\n    payload: dados.luminosidade\n};\n\nreturn [\n    distancia,\n    luminosidade,\n    statusAproximacao,\n    statusLuminosidade,\n    statusGeral,\n    graficoDistancia,\n    graficoLuminosidade\n];",
